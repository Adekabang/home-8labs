---
interface Props {
  href: string;
  size?: "md" | "lg";
  block?: boolean;
  style?: "outline" | "primary" | "inverted" | "muted";
  class?: string;
  [x: string]: any;
}

const {
  href,
  block,
  size = "lg",
  style = "primary",
  class: className,
  ...rest
} = Astro.props;

const rel = rest.target === "_blank" ? "noopener noreferrer" : undefined;

const sizes = {
  lg: "px-5 py-2.5 min-h-[2.75rem]",
  md: "px-4 py-2.5 min-h-[2.75rem]",
};

const styles = {
  outline: "bg-ink border border-grid text-line hover:bg-elevated",
  // red-ink bg so white label clears WCAG AA (6.05:1) vs 3.57 on #FF2D75
  primary: "bg-red-ink text-white border border-red-ink hover:bg-red-800",
  inverted: "bg-line text-ink border border-line",
  muted: "bg-elevated hover:bg-grid text-line border border-grid",
};
---

<a
  href={href}
  rel={rel}
  {...rest}
  class:list={[
    "inline-flex items-center justify-center gap-2 rounded-none text-center text-sm font-medium transition",
    block && "w-full",
    sizes[size],
    styles[style],
    className,
  ]}
  ><slot />
</a>
