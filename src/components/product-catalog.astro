---
import Link from "@components/ui/link.astro";
import NestedSandboxCubes from "@components/motifs/nested-sandbox-cubes.astro";
import DedicatedComputeCore from "@components/motifs/dedicated-compute-core.astro";
import DeploymentRunway from "@components/motifs/deployment-runway.astro";

const posters = [
  {
    numeral: "I",
    label: "Virtual Lab Infrastructure",
    title: "Nested labs for controlled failure.",
    body: "Experiment-grade environments. Break things, rebuild, repeat — without touching production.",
    href: "https://my.8labs.id/products/virtual-labs",
    motif: "sandbox",
  },
  {
    numeral: "II",
    label: "Dedicated Compute Matrix",
    title: "Predictable VMs with hard boundaries.",
    body: "KVM machines for steady workloads. Public IPv6, on-server snapshots, clear limits.",
    href: "https://my.8labs.id/products/virtual-dedicated-labs",
    motif: "core",
  },
  {
    numeral: "III",
    label: "Elastic Deployment Layer",
    title: "Scale paths from NAT to cloud.",
    body: "CloudLabs, ElasticLabs, and NAT tiers. Grow disk and network as the work expands.",
    href: "https://my.8labs.id/products/elasticlabs",
    motif: "runway",
  },
];
---

<section class="mt-32">
  <div class="flex items-baseline justify-between gap-6 border-b border-grid pb-5">
    <p class="micro-label">Product Catalog</p>
    <p class="micro-label hidden sm:block">Confirm stock & price · my.8labs.id</p>
  </div>

  <div class="mt-10 grid grid-cols-1 gap-px overflow-hidden border border-grid bg-grid md:grid-cols-3">
    {
      posters.map((p) => (
        <a
          href={p.href}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative flex flex-col bg-ink p-6 transition-colors duration-300 hover:bg-panel">
          {/* framed visual area — dominant top */}
          <div class="relative flex h-80 items-center justify-center overflow-hidden border border-grid bg-surface lg:h-96">
            <div class="absolute inset-0 opacity-[0.12] blueprint-grid" />
            {p.motif === "sandbox" && <NestedSandboxCubes class="relative h-72 w-auto lg:h-80" />}
            {p.motif === "core" && <DedicatedComputeCore class="relative h-72 w-auto lg:h-80" />}
            {p.motif === "runway" && <DeploymentRunway class="relative h-72 w-auto lg:h-80" />}
          </div>

          {/* headline + copy */}
          <div class="mt-6 flex flex-1 flex-col">
            <p class="micro-label text-red-ink">{p.label}</p>
            <h3 class="mt-3 text-2xl font-light leading-snug tracking-[-0.02em] text-line">
              {p.title}
            </h3>
            <p class="mt-3 text-sm leading-relaxed text-cool">{p.body}</p>
            <span class="mt-auto pt-6 inline-flex items-center gap-2 text-xs font-medium uppercase tracking-[0.16em] text-line">
              <span class="h-px w-6 bg-red-700 transition-all group-hover:w-10" />
              View architecture
            </span>
          </div>
        </a>
      ))
    }
  </div>

  <div class="mt-px flex flex-col gap-4 border border-t-0 border-grid bg-surface p-6 sm:flex-row sm:items-center sm:justify-between">
    <p class="max-w-2xl text-sm leading-relaxed text-cool">
      Virtual Labs bill in LAB Coin — 100 free at signup. Other families bill in IDR. Final price and stock are confirmed in the panel.
    </p>
    <Link href="https://my.8labs.id" target="_blank" rel="noopener noreferrer" size="md" class="rounded-none shrink-0">
      Open client panel
    </Link>
  </div>
</section>
