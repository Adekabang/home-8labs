---
import Button from "./ui/button.astro";
---

<!-- To make this contact form work, create your free access key from https://web3forms.com/
     Then you will get all form submissions in your email inbox. -->
<form
  action="https://api.8labs.id/submit"
  method="POST"
  id="form"
  class="needs-validation"
  novalidate>
  <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
  <!-- Create your free access key from https://web3forms.com/ -->
  <input type="checkbox" class="hidden" style="display:none" name="botcheck" />
  <div class="mb-5">
    <label for="full_name" class="mb-1 block text-sm font-medium text-gray-700"
      >Full name</label
    >
    <input
      id="full_name"
      type="text"
      placeholder="Jane Doe"
      required
      aria-describedby="name_error"
      class="w-full px-4 py-3 border-2 placeholder:text-gray-500 rounded-md outline-none focus:ring-2 border-gray-300 focus:border-red-600 ring-red-200"
      name="name"
    />
    <div
      id="name_error"
      role="alert"
      class="empty-feedback invalid-feedback text-red-600 text-sm mt-1"
    >
      Please provide your full name.
    </div>
  </div>
  <div class="mb-5">
    <label
      for="email_address"
      class="mb-1 block text-sm font-medium text-gray-700">Email address</label
    >
    <input
      id="email_address"
      type="email"
      placeholder="you@example.com"
      name="email"
      required
      aria-describedby="email_empty email_invalid"
      class="w-full px-4 py-3 border-2 placeholder:text-gray-500 rounded-md outline-none focus:ring-2 border-gray-300 focus:border-red-600 ring-red-200"
    />
    <div id="email_empty" role="alert" class="empty-feedback text-red-600 text-sm mt-1">
      Please provide your email address.
    </div>
    <div id="email_invalid" role="alert" class="invalid-feedback text-red-600 text-sm mt-1">
      Please provide a valid email address.
    </div>
  </div>
  <div class="mb-3">
    <label for="message" class="mb-1 block text-sm font-medium text-gray-700"
      >Message</label
    >
    <textarea
      id="message"
      name="message"
      required
      placeholder="How can we help?"
      aria-describedby="message_error"
      class="w-full px-4 py-3 border-2 placeholder:text-gray-500 rounded-md outline-none h-36 focus:ring-2 border-gray-300 focus:border-red-600 ring-red-200"
    ></textarea>
    <div
      id="message_error"
      role="alert"
      class="empty-feedback invalid-feedback text-red-600 text-sm mt-1"
    >
      Please enter your message.
    </div>
  </div>
  <Button type="submit" size="lg" block>Send message</Button>
  <div id="result" class="mt-3 text-center" role="status" aria-live="polite">
  </div>
</form>

<style>
  .invalid-feedback,
  .empty-feedback {
    display: none;
  }

  .was-validated :placeholder-shown:invalid ~ .empty-feedback {
    display: block;
  }

  .was-validated :not(:placeholder-shown):invalid ~ .invalid-feedback {
    display: block;
  }

  .is-invalid,
  .was-validated :invalid {
    border-color: #dc3545;
  }
</style>

<script is:inline>
  const form = document.getElementById("form");
  const result = document.getElementById("result");

  form.addEventListener("submit", function (e) {
    e.preventDefault();
    form.classList.add("was-validated");
    if (!form.checkValidity()) {
      form.querySelectorAll(":invalid")[0].focus();
      return;
    }
    const formData = new FormData(form);
    const object = Object.fromEntries(formData);
    const json = JSON.stringify(object);

    result.classList.remove("text-green-600", "text-red-600");
    result.style.display = "";
    result.textContent = "Sending your message...";

    let ok = false;
    fetch("https://api.8labs.id/submit", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        Accept: "application/json",
      },
      body: json,
    })
      .then(async (response) => {
        let json = await response.json();
        if (response.status == 200) {
          ok = true;
          result.classList.add("text-green-600");
          result.textContent =
            json.message || "Thanks — your message has been sent.";
        } else {
          result.classList.add("text-red-600");
          result.textContent =
            json.message ||
            "We could not send your message. Please try Telegram @virtual_8labs.";
        }
      })
      .catch(() => {
        result.classList.add("text-red-600");
        result.textContent =
          "Something went wrong. Please reach us on Telegram @virtual_8labs.";
      })
      .then(function () {
        if (ok) {
          form.reset();
          form.classList.remove("was-validated");
        }
      });
  });
</script>
