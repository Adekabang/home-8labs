---
// Ready State Runway — a low deployment launch pad with a slab on the pad and
// a ready-state line. CTA motif (distinct from the pyramid/matrix).
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<svg
  viewBox="0 0 600 260"
  data-motif
  class:list={[className]}
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-labelledby="rsr-t rsr-d"
  preserveAspectRatio="xMidYMax meet">
  <title id="rsr-t">Ready state runway</title>
  <desc id="rsr-d">A low deployment launch pad holding a pink-red slab, with a ready-state activation line.</desc>
  <defs>
    <linearGradient id="rsrSlab" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#C20E50"></stop>
      <stop offset="1" stop-color="#E4E4E7"></stop>
    </linearGradient>
    <radialGradient id="rsrGlow" cx="0.5" cy="0.85" r="0.5">
      <stop offset="0" stop-color="#C20E50" stop-opacity="0"></stop>
      <stop offset="1" stop-color="#C20E50" stop-opacity="0"></stop>
    </radialGradient>
  </defs>

  <rect x="180" y="120" width="240" height="140" fill="url(#rsrGlow)" class="glow"></rect>

  <!-- perspective pad rails -->
  <g fill="none" stroke="#0A0A0A" stroke-opacity="0.3" stroke-width="1">
    <path class="draw" pathLength="1" d="M120 250 L255 168 M480 250 L345 168 M255 168 H345"></path>
  </g>

  <!-- launch pad slabs (low, flat) -->
  <g stroke="#0A0A0A" stroke-opacity="0.85" stroke-width="1" stroke-linejoin="round">
    <polygon class="rise" style="--i:0" points="240,210 360,210 384,232 216,232" fill="#F4F4F5"></polygon>
    <polygon class="rise" style="--i:1" points="258,188 342,188 360,206 240,206" fill="#FFFFFF"></polygon>
  </g>

  <!-- central deployment slab on the pad -->
  <g class="lift" stroke="#0A0A0A" stroke-opacity="0.9" stroke-width="1.1" stroke-linejoin="round">
    <polygon points="276,150 324,150 336,140 288,140" fill="#FFFFFF"></polygon>
    <polygon points="324,150 324,186 336,176 336,140" fill="#E4E4E7"></polygon>
    <rect x="276" y="150" width="48" height="36" fill="url(#rsrSlab)"></rect>
  </g>

  <!-- ready-state activation line -->
  <g>
    <line class="ready" x1="216" x2="384" y1="124" y2="124" stroke="#C20E50" stroke-width="1.4" pathLength="1"></line>
    <circle cx="216" cy="124" r="2.5" fill="#C20E50" class="rdot"></circle>
    <circle cx="384" cy="124" r="2.5" fill="#C20E50" class="rdot"></circle>
  </g>
  <text x="300" y="116" text-anchor="middle" font-family="monospace" font-size="8" letter-spacing="3" fill="#68727F" class="lbl">READY · ARMED</text>

  <style>
    @media (prefers-reduced-motion: no-preference) {
      .draw,
      .ready {
        stroke-dasharray: 1;
        stroke-dashoffset: 1;
        animation: rsr-draw 1.4s ease forwards;
      }
      .ready {
        animation-delay: 1.1s;
        animation-duration: 0.9s;
      }
      .rise {
        opacity: 0;
        transform-box: fill-box;
        animation: rsr-rise 0.55s cubic-bezier(0.2, 0.6, 0.2, 1) forwards;
        animation-delay: calc(0.5s + var(--i) * 0.15s);
      }
      .lift {
        opacity: 0;
        transform-box: fill-box;
        animation: rsr-lift 0.6s cubic-bezier(0.2, 0.6, 0.2, 1) forwards 0.95s;
      }
      .lbl {
        opacity: 0;
        animation: rsr-fade 0.6s ease forwards 1.6s;
      }
      .rdot {
        animation: rsr-pulse 2.2s ease-in-out infinite 1.6s;
      }
      .glow {
        animation: rsr-pulse 4s ease-in-out infinite 1.8s;
      }
    }
    @keyframes rsr-draw {
      to {
        stroke-dashoffset: 0;
      }
    }
    @keyframes rsr-rise {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    @keyframes rsr-lift {
      from {
        opacity: 0;
        transform: translateY(14px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    @keyframes rsr-fade {
      to {
        opacity: 1;
      }
    }
    @keyframes rsr-pulse {
      0%,
      100% {
        opacity: 0.4;
      }
      50% {
        opacity: 1;
      }
    }
  </style>
</svg>
