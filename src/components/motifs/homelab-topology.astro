---
// Homelab network topology — uplink → router → switch fanning out to nodes
// (Proxmox host, NAS, Pi, and an isolated lab VM in crimson). Traffic pulses
// flow down the links, the active lab node blinks behind a dashed boundary.
// Light blueprint aesthetic: 1px black strokes, near-white faces, crimson accent.
// ponytail: pure CSS/SVG, no JS — offset-path drives the traffic pulses.
interface Props {
  class?: string;
}
const { class: className } = Astro.props;

// link geometry — reused verbatim in the <style> offset-path rules
const L_TRUNK = "M260 124 L260 160";
const L_N1 = "M210 200 C 150 235, 74 252, 74 292";
const L_N3 = "M280 200 C 295 246, 330 252, 330 292";
const L_N4 = "M310 200 C 380 235, 452 252, 452 292";

const nodes = [
  { x: 28, label: "KVM", accent: false },
  { x: 156, label: "NAS", accent: false },
  { x: 284, label: "PI", accent: false },
  { x: 406, label: "LAB", accent: true },
];
---

<svg
  viewBox="0 0 520 460"
  data-motif
  class:list={[className]}
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-labelledby="ht-t ht-d">
  <title id="ht-t">Homelab network topology</title>
  <desc id="ht-d">An uplink feeding a router and switch that fans out to a Proxmox host, NAS, Pi, and an isolated lab VM, with traffic pulses flowing along the links.</desc>

  <!-- links -->
  <g class="link" fill="none" stroke="#A1A1AA" stroke-width="1.1">
    <path d="M260 52 L260 84" pathLength="1"></path>
    <path d={L_TRUNK} pathLength="1"></path>
    <path d={L_N1} pathLength="1"></path>
    <path d="M240 200 C 225 246, 202 252, 202 292" pathLength="1"></path>
    <path d={L_N3} pathLength="1"></path>
    <path d={L_N4} pathLength="1"></path>
  </g>

  <!-- traffic pulses (switch distributing down the fan) -->
  <g fill="#C20E50">
    <circle class="pkt k1" r="2.8"></circle>
    <circle class="pkt k2" r="2.8"></circle>
    <circle class="pkt k3" r="2.8"></circle>
    <circle class="pkt k4" r="2.8"></circle>
    <circle class="pkt k5" r="2.8"></circle>
  </g>

  <!-- uplink -->
  <g class="node">
    <rect x="214" y="26" width="92" height="26" rx="6" fill="#FFFFFF" stroke="#A1A1AA" stroke-width="1" stroke-dasharray="4 3"></rect>
    <text x="260" y="43" text-anchor="middle" font-family="ui-monospace,monospace" font-size="9" letter-spacing="1.5" fill="#A1A1AA">UPLINK</text>
  </g>

  <!-- router -->
  <g class="node" stroke="#0A0A0A" stroke-width="1.2" stroke-linejoin="round">
    <rect x="210" y="84" width="100" height="40" rx="8" fill="#FFFFFF"></rect>
    <line x1="226" y1="78" x2="226" y2="70" stroke="#A1A1AA" stroke-width="1"></line>
    <line x1="294" y1="78" x2="294" y2="70" stroke="#A1A1AA" stroke-width="1"></line>
    <!-- status LEDs -->
    <circle class="blink" cx="220" cy="93" r="2.2" fill="#C20E50" stroke="none"></circle>
    <circle cx="227" cy="93" r="2.2" fill="#D4D4D8" stroke="none"></circle>
    <circle cx="234" cy="93" r="2.2" fill="#D4D4D8" stroke="none"></circle>
    <!-- broadcast bloom -->
    <g stroke="#C20E50" stroke-width="1" fill="none" stroke-opacity="0.55">
      <path d="M293 106 A5 5 0 0 1 298 101"></path>
      <path d="M289 106 A9 9 0 0 1 298 97"></path>
      <path d="M285 106 A13 13 0 0 1 298 93"></path>
    </g>
    <circle cx="298" cy="106" r="1.6" fill="#C20E50" stroke="none"></circle>
    <text x="252" y="105" text-anchor="middle" font-family="ui-monospace,monospace" font-size="8" letter-spacing="1.5" fill="#0A0A0A" stroke="none">ROUTER</text>
    <!-- ports -->
    <g fill="none" stroke="#0A0A0A" stroke-opacity="0.3" stroke-width="0.9">
      {[228, 238, 248, 258, 268].map((px) => (
        <rect x={px} y="113" width="7" height="6" rx="1"></rect>
      ))}
    </g>
  </g>

  <!-- switch — rackmount faceplate -->
  <g class="node" stroke-linejoin="round">
    <text x="158" y="151" font-family="ui-monospace,monospace" font-size="8" letter-spacing="1.5" fill="#A1A1AA">SWITCH</text>
    <rect x="150" y="156" width="220" height="44" rx="8" fill="#FFFFFF" stroke="#0A0A0A" stroke-width="1.2"></rect>

    <!-- status LED -->
    <circle class="blink" cx="170" cy="178" r="4" fill="#C20E50" stroke="none"></circle>

    <!-- port / node ring cluster -->
    <g stroke="#0A0A0A" stroke-width="1" fill="#FFFFFF">
      <line x1="192" y1="178" x2="198" y2="178" stroke="#A1A1AA"></line>
      <line x1="206" y1="178" x2="212" y2="178" stroke="#A1A1AA"></line>
      <circle cx="188" cy="178" r="4.5"></circle>
      <circle cx="202" cy="178" r="4.5"></circle>
      <circle cx="216" cy="178" r="4.5"></circle>
      <circle cx="188" cy="178" r="1.4" fill="#0A0A0A" stroke="none"></circle>
      <circle cx="202" cy="178" r="1.4" fill="#0A0A0A" stroke="none"></circle>
      <circle cx="216" cy="178" r="1.4" fill="#0A0A0A" stroke="none"></circle>
    </g>

    <!-- diamond motif -->
    <g stroke="#C20E50" stroke-width="1.2" fill="none">
      <polygon points="232,170 240,178 232,186 224,178"></polygon>
      <line x1="224" y1="178" x2="240" y2="178" stroke-opacity="0.5"></line>
      <line x1="232" y1="170" x2="232" y2="186" stroke-opacity="0.5"></line>
    </g>

    <!-- second LED -->
    <circle class="blink b-b" cx="252" cy="178" r="4" fill="#C20E50" stroke="none"></circle>

    <!-- port-bank fins -->
    <g fill="#0A0A0A" stroke="none">
      {[266, 272, 278, 284, 294, 300, 306, 312].map((px, i) => (
        <rect class="fin" style={`animation-delay:${1 + i * 0.12}s`} x={px} y="167" width="3" height="22"></rect>
      ))}
    </g>

    <!-- identity badge -->
    <rect x="322" y="170" width="36" height="16" rx="3" fill="#C20E50" stroke="none"></rect>
    <text x="340" y="181" text-anchor="middle" font-family="ui-monospace,monospace" font-size="7" letter-spacing="1" fill="#FFFFFF" stroke="none">8LABS</text>
  </g>

  <!-- nodes -->
  {
    nodes.map((n) => {
      const cx = n.x + 46;
      return (
        <g
          class="node"
          stroke={n.accent ? "#C20E50" : "#0A0A0A"}
          stroke-width="1.2"
          stroke-linejoin="round">
          {n.accent && (
            <rect
              x={n.x - 8}
              y="284"
              width="108"
              height="86"
              rx="6"
              fill="none"
              stroke="#C20E50"
              stroke-width="1"
              stroke-dasharray="4 3"
              opacity="0.6"
            />
          )}
          <rect x={n.x} y="292" width="92" height="70" rx="7" fill={n.accent ? "#FBE9EF" : "#FFFFFF"} />
          {/* status LED */}
          <circle class={n.accent ? "led blink" : "led"} cx={n.x + 80} cy="301" r="2.2" fill={n.accent ? "#C20E50" : "#D4D4D8"} stroke="none" />

          {/* KVM — hypervisor guests */}
          {n.label === "KVM" && (
            <g stroke-width="0.9">
              <rect x={n.x + 12} y="306" width="64" height="7" rx="1.5" fill="#FBE9EF" stroke="#C20E50" stroke-opacity="0.6" />
              <rect x={n.x + 12} y="317" width="64" height="7" rx="1.5" fill="#F4F4F5" stroke="#0A0A0A" stroke-opacity="0.25" />
              <rect x={n.x + 12} y="328" width="64" height="7" rx="1.5" fill="#F4F4F5" stroke="#0A0A0A" stroke-opacity="0.25" />
            </g>
          )}

          {/* NAS — disk bays */}
          {n.label === "NAS" && (
            <g stroke="#0A0A0A" stroke-opacity="0.35" stroke-width="0.9" fill="#FFFFFF">
              {[14, 30, 46, 62].map((d) => (
                <g>
                  <rect x={n.x + d} y="306" width="12" height="28" rx="1.5" />
                  <line x1={n.x + d + 2} y1="311" x2={n.x + d + 10} y2="311" />
                </g>
              ))}
            </g>
          )}

          {/* PI — single-board computer */}
          {n.label === "PI" && (
            <g>
              {[14, 21, 28, 35, 42, 49, 56, 63, 70].map((d) => (
                <circle cx={n.x + d} cy="305" r="1.1" fill="#0A0A0A" fill-opacity="0.4" stroke="none" />
              ))}
              <rect x={n.x + 30} y="314" width="24" height="18" rx="1.5" fill="#F4F4F5" stroke="#0A0A0A" stroke-opacity="0.4" stroke-width="0.9" />
              <circle cx={n.x + 42} cy="323" r="1.6" fill="#C20E50" stroke="none" />
              <rect x={n.x + 13} y="316" width="9" height="6" rx="1" fill="#FFFFFF" stroke="#0A0A0A" stroke-opacity="0.35" stroke-width="0.9" />
              <rect x={n.x + 13} y="326" width="9" height="6" rx="1" fill="#FFFFFF" stroke="#0A0A0A" stroke-opacity="0.35" stroke-width="0.9" />
            </g>
          )}

          {/* LAB — isolated terminal */}
          {n.accent && (
            <g>
              <rect x={n.x + 12} y="304" width="64" height="30" rx="2" fill="#FFFFFF" stroke="#C20E50" stroke-opacity="0.5" stroke-width="0.9" />
              <line x1={n.x + 12} y1="312" x2={n.x + 76} y2="312" stroke="#C20E50" stroke-opacity="0.4" stroke-width="0.9" />
              <text x={n.x + 18} y="328" font-family="ui-monospace,monospace" font-size="10" fill="#C20E50" stroke="none">›</text>
              <rect class="blink" x={n.x + 27} y="321" width="7" height="8" fill="#C20E50" stroke="none" />
            </g>
          )}
          <text x={cx} y="350" text-anchor="middle" font-family="ui-monospace,monospace" font-size="9" letter-spacing="1.5" fill={n.accent ? "#C20E50" : "#0A0A0A"} stroke="none">
            {n.label}
          </text>
        </g>
      );
    })
  }
</svg>

<style>
    .pkt { opacity: 0 }
    @media (prefers-reduced-motion: no-preference) {
      .node { opacity: 0; transform-box: fill-box; animation: rise 0.5s cubic-bezier(0.22,1,0.36,1) forwards }
      .node:nth-of-type(3) { animation-delay: 0.08s }
      .node:nth-of-type(4) { animation-delay: 0.16s }
      .node:nth-of-type(5) { animation-delay: 0.3s }
      .node:nth-of-type(6) { animation-delay: 0.38s }
      .node:nth-of-type(7) { animation-delay: 0.46s }
      .node:nth-of-type(8) { animation-delay: 0.54s }
      .node:nth-of-type(9) { animation-delay: 0.62s }
      .link path { stroke-dasharray: 1; stroke-dashoffset: 1; animation: draw 0.8s ease forwards 0.3s }
      .fin { opacity: 0.25; animation: flicker 1.8s ease-in-out infinite }
      .b-b { animation-delay: 2.3s }

      .pkt { offset-rotate: 0deg; animation: hop 2.6s linear infinite 1s }
      .k1 { offset-path: path("M260 124 L260 160") }
      .k2 { offset-path: path("M210 200 C 150 235, 74 252, 74 292"); animation-delay: 1.7s }
      .k3 { offset-path: path("M280 200 C 295 246, 330 252, 330 292"); animation-delay: 2s }
      .k4 { offset-path: path("M310 200 C 380 235, 452 252, 452 292"); animation-delay: 2.3s }
      .k5 { offset-path: path("M240 200 C 225 246, 202 252, 202 292"); animation-delay: 1.85s }

      .blink { animation: blink 2.2s ease-in-out infinite 1.2s }
    }
    @keyframes rise { from { opacity: 0; transform: translateY(10px) } to { opacity: 1; transform: translateY(0) } }
    @keyframes draw { to { stroke-dashoffset: 0 } }
    @keyframes hop {
      0% { offset-distance: 0%; opacity: 0 }
      6% { opacity: 1 }
      34% { offset-distance: 100%; opacity: 1 }
      38%, 100% { offset-distance: 100%; opacity: 0 }
    }
    @keyframes blink { 0%, 100% { opacity: 1 } 50% { opacity: 0.25 } }
    @keyframes flicker { 0%, 100% { opacity: 0.25 } 50% { opacity: 1 } }
</style>
