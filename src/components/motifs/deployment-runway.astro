---
// Elastic / Cloud — a base node fanning out along connection paths to nodes
// climbing toward the cloud, the destination node in red. "Scale NAT to cloud."
interface Props { class?: string }
const { class: className } = Astro.props;
const K = 0.5;
function cuboid(cx: number, cy: number, s: number, h: number) {
  const wx = s * 0.866;
  const T = [cx, cy - s * K], R = [cx + wx, cy], F = [cx, cy + s * K], L = [cx - wx, cy];
  const R2 = [R[0], R[1] + h], F2 = [F[0], F[1] + h], L2 = [L[0], L[1] + h];
  const p = (a: number[]) => `${a[0]},${a[1]}`;
  return { top: [T, R, F, L].map(p).join(" "), left: [L, F, F2, L2].map(p).join(" "), right: [R, F, F2, R2].map(p).join(" "), c: [cx, cy] };
}
const base = cuboid(96, 232, 64, 30);       // NAT origin (large)
const mid1 = cuboid(186, 196, 40, 22);
const mid2 = cuboid(246, 156, 36, 20);
const cloud = cuboid(306, 120, 44, 26);     // destination (red)
const nodes = [base, mid1, mid2, cloud];
// connection paths (base → mid1 → mid2 → cloud)
const links = [
  `M${base.c[0]} ${base.c[1]} L${mid1.c[0]} ${mid1.c[1]}`,
  `M${mid1.c[0]} ${mid1.c[1]} L${mid2.c[0]} ${mid2.c[1]}`,
  `M${mid2.c[0]} ${mid2.c[1]} L${cloud.c[0]} ${cloud.c[1]}`,
  `M${base.c[0]} ${base.c[1]} L${mid2.c[0]} ${mid2.c[1]}`,
];
---
<svg viewBox="0 0 380 300" data-motif class:list={[className]} xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="dr-t dr-d">
  <title id="dr-t">Scaling node network</title>
  <desc id="dr-d">An isometric network of nodes connected by paths, climbing from a base node to a red cloud node.</desc>
  <!-- connection paths -->
  <g class="links" stroke="#A1A1AA" stroke-width="1" fill="none" stroke-dasharray="3 3">
    {links.map((d) => <path d={d} pathLength="1"></path>)}
  </g>
  <!-- nodes -->
  {nodes.map((n, i) => {
    const accent = i === nodes.length - 1;
    return (
      <g class="rise" stroke={accent ? "#C20E50" : "#0A0A0A"} stroke-width={accent ? "1.3" : "1.1"} stroke-opacity={accent ? "1" : "0.85"} stroke-linejoin="round">
        <polygon points={n.left} fill={accent ? "#EFC4D2" : "#ECECEF"}></polygon>
        <polygon points={n.right} fill={accent ? "#E6ABBE" : "#E4E4E7"}></polygon>
        <polygon points={n.top} fill={accent ? "#F7DCE5" : "#FAFAFA"}></polygon>
      </g>
    );
  })}
  <style>
    @media (prefers-reduced-motion: no-preference) {
      .rise { opacity: 0; transform-box: fill-box; animation: u 0.5s cubic-bezier(0.22,1,0.36,1) forwards }
      .rise:nth-of-type(2) { animation-delay: 0.1s }
      .rise:nth-of-type(3) { animation-delay: 0.22s }
      .rise:nth-of-type(4) { animation-delay: 0.34s }
      .links path { stroke-dasharray: 1; stroke-dashoffset: 1; animation: d 0.9s ease forwards 0.4s }
    }
    @keyframes u { from { opacity: 0; transform: translateY(12px) } to { opacity: 1; transform: translateY(0) } }
    @keyframes d { to { stroke-dashoffset: 0 } }
  </style>
</svg>
