---
// Elastic Labs — autoscaling. A load curve rises and the deployment scales out
// (2 → 4 replicas) then scales back in, on loop. A balancer fans traffic to the
// steady replicas; the elastic replicas pop in/out, newest in crimson.
// "Scale paths from NAT to cloud." Light blueprint aesthetic.
interface Props { class?: string }
const { class: className } = Astro.props;
const reps = [
  { x: 36, cls: "rep r1", accent: false },
  { x: 116, cls: "rep r2", accent: false },
  { x: 196, cls: "rep r3", accent: false },
  { x: 276, cls: "rep r4", accent: true },
];
const LINKS = [
  "M180 100 C 140 124, 60 134, 60 168",
  "M180 100 C 162 128, 140 142, 140 168",
];
---
<svg viewBox="0 0 360 300" data-motif class:list={[className]} xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="el-t el-d">
  <title id="el-t">Autoscaling replicas</title>
  <desc id="el-d">A rising load curve driving a balancer that scales out replica instances and back in.</desc>

  <!-- load curve -->
  <g>
    <rect x="118" y="16" width="124" height="46" rx="6" fill="#FFFFFF" stroke="#E4E4E7" stroke-width="1"></rect>
    <text x="128" y="32" font-family="ui-monospace,monospace" font-size="7" letter-spacing="1" fill="#A1A1AA" stroke="none">LOAD</text>
    <polyline class="load" points="128,54 150,50 168,42 188,44 208,30 234,24" pathLength="1" fill="none" stroke="#0A0A0A" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></polyline>
    <circle class="load-tip" cx="234" cy="24" r="2.6" fill="#C20E50" stroke="none"></circle>
  </g>

  <!-- balancer -->
  <g class="plate" stroke="#0A0A0A" stroke-width="1.2" stroke-linejoin="round">
    <rect x="150" y="76" width="60" height="26" rx="6" fill="#FFFFFF"></rect>
    <text x="180" y="93" text-anchor="middle" font-family="ui-monospace,monospace" font-size="8" letter-spacing="1.5" fill="#0A0A0A" stroke="none">LB</text>
  </g>

  <!-- links to steady replicas -->
  <g class="link" fill="none" stroke="#A1A1AA" stroke-width="1.1">
    {LINKS.map((d) => <path d={d} pathLength="1"></path>)}
  </g>
  <!-- elastic links (fade in/out with replicas 3 & 4) -->
  <g fill="none" stroke="#A1A1AA" stroke-width="1.1">
    <path class="elink ea" d="M180 100 C 200 126, 220 142, 220 168"></path>
    <path class="elink eb" d="M180 100 C 235 122, 300 132, 300 168"></path>
  </g>
  <g fill="#C20E50">
    <circle class="pkt k1" r="2.4"></circle>
    <circle class="pkt k2" r="2.4"></circle>
  </g>

  <!-- replicas -->
  {reps.map((r) => (
    <g class={r.cls} stroke={r.accent ? "#C20E50" : "#0A0A0A"} stroke-width="1.1" stroke-linejoin="round">
      <rect x={r.x} y="168" width="48" height="58" rx="6" fill={r.accent ? "#FBE9EF" : "#FFFFFF"}></rect>
      <line x1={r.x + 8} y1="182" x2={r.x + 40} y2="182" stroke-opacity="0.25" stroke-width="0.9"></line>
      <circle class="led" cx={r.x + 10} cy="176" r="1.8" fill={r.accent ? "#C20E50" : "#D4D4D8"} stroke="none"></circle>
      <line x1={r.x + 10} y1="196" x2={r.x + 38} y2="196" stroke-opacity="0.3" stroke-width="0.9"></line>
      <line x1={r.x + 10} y1="206" x2={r.x + 30} y2="206" stroke-opacity="0.3" stroke-width="0.9"></line>
    </g>
  ))}

</svg>

<style>
    .pkt { opacity: 0 }
    .elink { opacity: 1 }
    @media (prefers-reduced-motion: no-preference) {
      .elink { opacity: 0; animation: fadeA 5s ease-in-out infinite 1s }
      .eb { animation-name: fadeB }
      .load { stroke-dasharray: 1; stroke-dashoffset: 1; animation: loadDraw 5s ease-in-out infinite }
      .load-tip { animation: tip 5s ease-in-out infinite }
      .plate { opacity: 0; transform-box: fill-box; animation: rise 0.5s cubic-bezier(0.22,1,0.36,1) forwards }
      .link path { stroke-dasharray: 1; stroke-dashoffset: 1; animation: draw 0.8s ease forwards 0.3s }
      .led { animation: blink 2.4s ease-in-out infinite }
      .pkt { offset-rotate: 0deg; animation: hop 2.6s linear infinite 1s }
      .k1 { offset-path: path("M180 100 C 140 124, 60 134, 60 168") }
      .k2 { offset-path: path("M180 100 C 162 128, 140 142, 140 168"); animation-delay: 1.3s }

      .rep { transform-box: fill-box; transform-origin: center bottom }
      .r1, .r2 { opacity: 0; animation: rise 0.5s cubic-bezier(0.22,1,0.36,1) forwards 0.4s }
      .r2 { animation-delay: 0.55s }
      .r3 { animation: scaleA 5s ease-in-out infinite 1s }
      .r4 { animation: scaleB 5s ease-in-out infinite 1s }
    }
    @keyframes rise { from { opacity: 0; transform: translateY(10px) } to { opacity: 1; transform: translateY(0) } }
    @keyframes draw { to { stroke-dashoffset: 0 } }
    @keyframes blink { 0%, 100% { opacity: 1 } 50% { opacity: 0.3 } }
    @keyframes loadDraw { 0% { stroke-dashoffset: 1 } 45%, 70% { stroke-dashoffset: 0 } 100% { stroke-dashoffset: 0 } }
    @keyframes tip { 0%, 30% { opacity: 0 } 45% { opacity: 1 } 100% { opacity: 1 } }
    @keyframes hop {
      0% { offset-distance: 0%; opacity: 0 }
      6% { opacity: 1 }
      34% { offset-distance: 100%; opacity: 1 }
      38%, 100% { offset-distance: 100%; opacity: 0 }
    }
    @keyframes scaleA {
      0%, 26% { opacity: 0; transform: scale(0) }
      36%, 80% { opacity: 1; transform: scale(1) }
      90%, 100% { opacity: 0; transform: scale(0) }
    }
    @keyframes scaleB {
      0%, 42% { opacity: 0; transform: scale(0) }
      52%, 70% { opacity: 1; transform: scale(1) }
      80%, 100% { opacity: 0; transform: scale(0) }
    }
    @keyframes fadeA { 0%, 30% { opacity: 0 } 38%, 80% { opacity: 1 } 90%, 100% { opacity: 0 } }
    @keyframes fadeB { 0%, 46% { opacity: 0 } 54%, 70% { opacity: 1 } 80%, 100% { opacity: 0 } }
</style>
