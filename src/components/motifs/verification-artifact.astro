---
// Trust — an isometric verified block inside a square inspection frame with
// corner brackets, a scan line, and a checksum tick. Clean line-art.
interface Props { class?: string }
const { class: className } = Astro.props;
const K = 0.5;
function cuboid(cx: number, cy: number, s: number, h: number) {
  const wx = s * 0.866;
  const T = [cx, cy - s * K], R = [cx + wx, cy], F = [cx, cy + s * K], L = [cx - wx, cy];
  const R2 = [R[0], R[1] + h], F2 = [F[0], F[1] + h], L2 = [L[0], L[1] + h];
  const p = (a: number[]) => `${a[0]},${a[1]}`;
  return { top: [T, R, F, L].map(p).join(" "), left: [L, F, F2, L2].map(p).join(" "), right: [R, F, F2, R2].map(p).join(" ") };
}
const block = cuboid(150, 150, 60, 56);
---
<svg viewBox="0 0 300 280" data-motif class:list={[className]} xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="va-t va-d">
  <title id="va-t">Verification artifact</title>
  <desc id="va-d">An isometric verified block inside a technical inspection frame with a scan line.</desc>
  <clipPath id="vaClip"><rect x="46" y="40" width="208" height="190"></rect></clipPath>
  <!-- inspection frame corner brackets -->
  <g stroke="#0A0A0A" stroke-width="1.2" fill="none" stroke-opacity="0.85">
    <path class="draw" pathLength="1" d="M46 70 V40 H76 M224 40 H254 V70 M254 200 V230 H224 M76 230 H46 V200"></path>
  </g>
  <!-- scan line -->
  <g clip-path="url(#vaClip)">
    <line class="scan" x1="46" x2="254" y1="0" y2="0" stroke="#C20E50" stroke-width="1.3"></line>
  </g>
  <!-- verified iso block -->
  <g class="lift" stroke="#0A0A0A" stroke-width="1.2" stroke-opacity="0.9" stroke-linejoin="round">
    <polygon points={block.left} fill="#F4F4F5"></polygon>
    <polygon points={block.right} fill="#ECECEF"></polygon>
    <polygon points={block.top} fill="#F7DCE5" stroke="#C20E50" stroke-width="1.3"></polygon>
  </g>
  <!-- check on the top face -->
  <path class="check" pathLength="1" d="M132 150 L145 162 L172 138" fill="none" stroke="#C20E50" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path>
  <text x="150" y="252" text-anchor="middle" font-family="monospace" font-size="9" letter-spacing="2" fill="#57575E">VERIFIED · 8LABS.ID</text>
  <style>
    @media (prefers-reduced-motion: no-preference) {
      .draw, .check { stroke-dasharray: 1; stroke-dashoffset: 1; animation: d 1s ease forwards }
      .lift { opacity: 0; transform-box: fill-box; animation: l 0.6s cubic-bezier(0.22,1,0.36,1) forwards 0.4s }
      .check { animation-delay: 0.9s; animation-duration: 0.4s }
      .scan { animation: s 3s ease-in-out infinite 1s }
    }
    @keyframes d { to { stroke-dashoffset: 0 } }
    @keyframes l { from { opacity: 0; transform: translateY(16px) } to { opacity: 1; transform: translateY(0) } }
    @keyframes s { 0% { transform: translateY(44px); opacity: 0 } 15%,85% { opacity: 0.8 } 100% { transform: translateY(226px); opacity: 0 } }
  </style>
</svg>
