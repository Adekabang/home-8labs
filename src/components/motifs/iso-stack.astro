---
// Isometric wireframe stack — line-art cuboids ascending from a base platform,
// the top cube accented in 8Labs red, wrapped in a dashed bounding box.
// Light blueprint aesthetic: 1px black strokes, near-white faces.
interface Props {
  class?: string;
}
const { class: className } = Astro.props;

const K = 0.5; // iso foreshorten
// Build a cuboid from the center of its TOP face.
function cuboid(cx: number, cy: number, s: number, h: number) {
  const wx = s * 0.866;
  const T = [cx, cy - s * K];
  const R = [cx + wx, cy];
  const F = [cx, cy + s * K];
  const L = [cx - wx, cy];
  const R2 = [R[0], R[1] + h];
  const F2 = [F[0], F[1] + h];
  const L2 = [L[0], L[1] + h];
  const p = (a: number[]) => `${a[0]},${a[1]}`;
  return {
    top: [T, R, F, L].map(p).join(" "),
    left: [L, F, F2, L2].map(p).join(" "),
    right: [R, F, F2, R2].map(p).join(" "),
    topCenter: [cx, cy],
  };
}

// base platform → 3 ascending cubes (top = accent)
const blocks = [
  { c: cuboid(260, 322, 138, 60), top: "#FFFFFF", l: "#F4F4F5", r: "#ECECEF", accent: false },
  { c: cuboid(260, 262, 72, 52), top: "#FFFFFF", l: "#F4F4F5", r: "#ECECEF", accent: false },
  { c: cuboid(260, 212, 58, 48), top: "#FFFFFF", l: "#F4F4F5", r: "#ECECEF", accent: false },
  { c: cuboid(260, 164, 48, 44), top: "#F7DCE5", l: "#EFC4D2", r: "#E6ABBE", accent: true },
];
const topCube = blocks[3].c;
---

<svg
  viewBox="0 0 520 460"
  data-motif
  class:list={[className]}
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-labelledby="iso-t iso-d">
  <title id="iso-t">Isometric platform stack</title>
  <desc id="iso-d">A wireframe isometric stack of cuboids rising from a base platform, the top block highlighted in red, wrapped in a dashed bounding box.</desc>

  <!-- faint ground reflection -->
  <g opacity="0.35" transform="translate(0 706) scale(1 -1)">
    <polygon points={blocks[0].c.top} fill="none" stroke="#D4D4D8" stroke-width="1" stroke-dasharray="2 3"></polygon>
  </g>

  <!-- ground shadow lozenge -->
  <polygon points={blocks[0].c.top} transform="translate(0 60)" fill="#000000" opacity="0.03"></polygon>

  <!-- stack, bottom → top -->
  {
    blocks.map((b) => (
      <g
        class="rise"
        stroke={b.accent ? "#C20E50" : "#0A0A0A"}
        stroke-width={b.accent ? "1.4" : "1.1"}
        stroke-linejoin="round"
        fill="none">
        <polygon points={b.c.left} fill={b.l}></polygon>
        <polygon points={b.c.right} fill={b.r}></polygon>
        <polygon points={b.c.top} fill={b.top}></polygon>
      </g>
    ))
  }

  <!-- dashed bounding box around the accent cube -->
  <g class="frame" stroke="#A1A1AA" stroke-width="1" stroke-dasharray="3 3" fill="none">
    <polygon points={cuboid(260, 150, 56, 56).top}></polygon>
    <polygon points={cuboid(260, 150, 56, 56).left}></polygon>
    <polygon points={cuboid(260, 150, 56, 56).right}></polygon>
  </g>

  <!-- leader line to the accent cube -->
  <g class="lead" stroke="#A1A1AA" stroke-width="1">
    <path d="M300 140 L372 116" fill="none"></path>
    <circle cx={topCube.topCenter[0]} cy={topCube.topCenter[1]} r="2.5" fill="#C20E50" stroke="none"></circle>
  </g>

  <style>
    @media (prefers-reduced-motion: no-preference) {
      .rise {
        opacity: 0;
        transform-box: fill-box;
        animation: iso-rise 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
      }
      .rise:nth-of-type(2) {
        animation-delay: 0.05s;
      }
      .rise:nth-of-type(3) {
        animation-delay: 0.18s;
      }
      .rise:nth-of-type(4) {
        animation-delay: 0.31s;
      }
      .rise:nth-of-type(5) {
        animation-delay: 0.44s;
      }
      .frame {
        opacity: 0;
        animation: iso-fade 0.5s ease forwards 0.7s;
      }
      .lead {
        opacity: 0;
        animation: iso-fade 0.5s ease forwards 0.9s;
      }
    }
    @keyframes iso-rise {
      from {
        opacity: 0;
        transform: translateY(16px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    @keyframes iso-fade {
      to {
        opacity: 1;
      }
    }
  </style>
</svg>
