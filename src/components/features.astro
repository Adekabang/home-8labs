---
// @ts-ignore
import { Icon } from "astro-icon/components";

const features = [
  {
    title: "Flexible lab environments",
    description:
      "Choose from nested Virtual Labs, straightforward Virtual Dedicated Labs, CloudLabs, ElasticLabs, or NAT-based labs depending on how much control, isolation, and networking your workload needs.",
    icon: "bx:cube",
  },
  {
    title: "IPv6, IPv4, and NAT options",
    description:
      "Product families expose different network models: public IPv6, public IPv4/IPv6, private IPv4, or NAT. Pick the plan that matches whether your lab needs direct public access or a lower-cost private setup.",
    icon: "bx:wifi",
  },
  {
    title: "Client panel ordering",
    description:
      "Use my.8labs.id to browse current stock, confirm pricing and billing unit, place orders, and manage services from one client panel.",
    icon: "bx:desktop",
  },
  {
    title: "Fast lab provisioning",
    description:
      "The public docs describe a registration, order, and access flow, with Virtual Labs typically ready within 1-15 minutes after the order flow completes.",
    icon: "bx:time-five",
  },
  {
    title: "Snapshots and recovery context",
    description:
      "Selected plans mention on-server snapshots or recovery options. For important workloads, keep your own backups because external backup is not implied.",
    icon: "bx:archive",
  },
  {
    title: "Docs, status, and support path",
    description:
      "Start from docs.8labs.id for usage guidance, check public status when available, and use the client panel or Telegram community for account and provisioning help.",
    icon: "bx:support",
  },
];
---

<div class="mt-20">
  <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
    8Labs features for practical <span
      class="text-red-700 underline decoration-black">ngoprek</span
    >.
  </h2>
  <p class="text-lg mt-4 text-slate-600 max-w-3xl">
    Build, test, break, and rebuild in lab environments designed for developers,
    students, IT professionals, and homelab users—without treating production
    infrastructure as your playground.
  </p>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 mt-16 gap-8">
  {
    features.map((item) => (
      <div class="group hover:bg-slate-50 p-6 rounded-xl transition-all duration-300 hover:shadow-lg border border-transparent hover:border-slate-200 text-center md:text-left">
        <div class="bg-black rounded-lg p-3 w-12 h-12 flex items-center justify-center mb-4 group-hover:bg-red-700 transition-colors duration-300 mx-auto md:mx-0">
          <Icon class="text-white w-6 h-6" name={item.icon} />
        </div>
        <h3 class="font-semibold text-lg mb-2 text-slate-900">{item.title}</h3>
        <p class="text-slate-600 text-sm leading-relaxed">{item.description}</p>
      </div>
    ))
  }
</div>
