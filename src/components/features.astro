---
// @ts-ignore
import { Icon } from "astro-icon/components";

const features = [
  {
    title: "IPv6 and IPv4 options",
    description:
      "Pick product families with public IPv6, public IPv4, private IPv4, or NAT depending on what your lab needs.",
    icon: "bx:wifi",
  },
  {
    title: "KVM lab environments",
    description:
      "Virtual Labs and dedicated VM options are built around KVM-based environments for hands-on experimentation.",
    icon: "bx:server",
  },
  {
    title: "Multiple performance tiers",
    description:
      "From low-cost NAT labs to higher-bandwidth CloudLabs, users can choose the right balance of network, storage, and price.",
    icon: "bx:rocket",
  },
  {
    title: "Client panel workflow",
    description:
      "Browse products, check stock, order, and manage services from the active my.8labs.id client panel.",
    icon: "bx:desktop",
  },
  {
    title: "Operational transparency",
    description:
      "A public status page, docs, Telegram community, and ticket path help users find the right support channel.",
    icon: "bx:shield",
  },
  {
    title: "Clear control and responsibility",
    description:
      "Labs are designed for admin-level experimentation; keep backups for important data and review plan details before ordering.",
    icon: "bx:cog",
  },
];
---

<div class="mt-20">
  <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
    Everything You Need to Start <span
      class="text-red-700 underline decoration-black">Ngoprek</span
    >.
  </h2>
  <p class="text-lg mt-4 text-slate-600 max-w-3xl">
    A practical cloud lab platform for developers, students, IT professionals,
    and homelab enthusiasts who need a place to test, break, rebuild, and learn
    without overcommitting production infrastructure.
  </p>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 mt-16 gap-8">
  {
    features.map((item) => (
      <div class="group hover:bg-slate-50 p-6 rounded-xl transition-all duration-300 hover:shadow-lg border border-transparent hover:border-slate-200 text-center md:text-left">
        <div class="bg-black rounded-lg p-3 w-12 h-12 flex items-center justify-center mb-4 group-hover:bg-red-700 transition-colors duration-300 mx-auto md:mx-0">
          <Icon class="text-white w-6 h-6" name={item.icon} />
        </div>
        <h3 class="font-semibold text-lg mb-2 text-slate-900">{item.title}</h3>
        <p class="text-slate-600 text-sm leading-relaxed">{item.description}</p>
      </div>
    ))
  }
</div>
