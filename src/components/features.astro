---
// @ts-ignore
import { Icon } from "astro-icon/components";

const features = [
  {
    title: "Pick the network model first",
    description:
      "Public product pages distinguish public IPv6, public IPv4/IPv6, private IPv4, and NAT options. Start with the connectivity your lab actually needs.",
    icon: "bx:wifi",
  },
  {
    title: "Use docs for first boot",
    description:
      "The public docs walk through registration, ordering a Virtual Lab, and accessing it through the client or cloud portal.",
    icon: "bx:book-open",
  },
  {
    title: "Plan for provisioning time",
    description:
      "The getting-started docs say a Virtual Lab is typically ready within 1-15 minutes after the order flow completes.",
    icon: "bx:time-five",
  },
  {
    title: "Manage from the client panel",
    description:
      "Browse products, check stock, order, and manage services from my.8labs.id; use this landing page as a routing layer.",
    icon: "bx:desktop",
  },
  {
    title: "Snapshots are not external backups",
    description:
      "Some public listings mention snapshots for recovery, while the terms say users remain responsible for important backups.",
    icon: "bx:archive",
  },
  {
    title: "Experiment without overclaiming",
    description:
      "8Labs is positioned for developers, students, IT professionals, and homelab users who want practical cloud lab environments.",
    icon: "bx:cog",
  },
];
---

<div class="mt-20">
  <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
    Everything You Need to Start <span
      class="text-red-700 underline decoration-black">Ngoprek</span
    >.
  </h2>
  <p class="text-lg mt-4 text-slate-600 max-w-3xl">
    A practical cloud lab platform for developers, students, IT professionals,
    and homelab enthusiasts who need a place to test, break, rebuild, and learn
    without overcommitting production infrastructure.
  </p>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 mt-16 gap-8">
  {
    features.map((item) => (
      <div class="group hover:bg-slate-50 p-6 rounded-xl transition-all duration-300 hover:shadow-lg border border-transparent hover:border-slate-200 text-center md:text-left">
        <div class="bg-black rounded-lg p-3 w-12 h-12 flex items-center justify-center mb-4 group-hover:bg-red-700 transition-colors duration-300 mx-auto md:mx-0">
          <Icon class="text-white w-6 h-6" name={item.icon} />
        </div>
        <h3 class="font-semibold text-lg mb-2 text-slate-900">{item.title}</h3>
        <p class="text-slate-600 text-sm leading-relaxed">{item.description}</p>
      </div>
    ))
  }
</div>
