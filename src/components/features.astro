---
// @ts-ignore
import { Icon } from "astro-icon/components";

const features = [
  {
    title: "Seamless Networking",
    description:
      "Public IPv6 & private IPv4 addressing for secure, accessible labs.",
    icon: "bx:wifi",
  },
  {
    title: "Versatile OS Support",
    description:
      "KVM virtualization with Debian, Ubuntu, CentOS, Rocky, Alma & FreeBSD.",
    icon: "bx:server",
  },
  {
    title: "Blazing Fast Connectivity",
    description:
      "Up to 1Gbps local & 100Mbps international speeds for rapid access.",
    icon: "bx:rocket",
  },
  {
    title: "User-Friendly Console",
    description:
      "Intuitive VM management with noVNC desktop & xTerm.js terminal.",
    icon: "bx:desktop",
  },
  {
    title: "Reliable & Managed",
    description:
      "99.5% SLA with automated cleanup policies for optimal performance.",
    icon: "bx:shield",
  },
  {
    title: "Complete Control",
    description:
      "Full admin access to configure your environment exactly as needed.",
    icon: "bx:cog",
  },
];
---

<div class="mt-16 md:mt-0">
  <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
    Everything You Need to Start <span
      class="text-red-700 underline decoration-black">Ngoprek</span
    >.
  </h2>
  <p class="text-lg mt-4 text-slate-600">
    Dive into hands-on experimentation and build your perfect lab environment
    with 8Labs. Our cloud labs platform provides all the tools and features you
    need to get started with ease and efficiency.
  </p>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 mt-16 gap-8">
  {
    features.map((item) => (
      <div class="group hover:bg-slate-50 p-6 rounded-xl transition-all duration-300 hover:shadow-lg border border-transparent hover:border-slate-200 text-center md:text-left">
        <div class="bg-black rounded-lg p-3 w-12 h-12 flex items-center justify-center mb-4 group-hover:bg-red-700 transition-colors duration-300 mx-auto md:mx-0">
          <Icon class="text-white w-6 h-6" name={item.icon} />
        </div>
        <h3 class="font-semibold text-lg mb-2 text-slate-900">{item.title}</h3>
        <p class="text-slate-600 text-sm leading-relaxed">{item.description}</p>
      </div>
    ))
  }
</div>
