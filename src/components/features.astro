---
// @ts-ignore
import { Icon } from "astro-icon/components";

const features = [
  {
    title: "Flexible lab environments",
    description:
      "Choose from nested Virtual Labs, straightforward Virtual Dedicated Labs, CloudLabs, ElasticLabs, or NAT-based labs depending on how much control, isolation, and networking your workload needs.",
    icon: "bx:cube",
  },
  {
    title: "IPv6, IPv4, and NAT options",
    description:
      "Product families expose different network models: public IPv6, public IPv4/IPv6, private IPv4, or NAT. Pick the plan that matches whether your lab needs direct public access or a lower-cost private setup.",
    icon: "bx:wifi",
  },
  {
    title: "Client panel ordering",
    description:
      "Use my.8labs.id to browse current stock, confirm pricing and billing unit, place orders, and manage services from one client panel.",
    icon: "bx:desktop",
  },
  {
    title: "Fast lab provisioning",
    description:
      "The public docs describe a registration, order, and access flow, with Virtual Labs typically ready within 1-15 minutes after the order flow completes.",
    icon: "bx:time-five",
  },
  {
    title: "Snapshots and recovery context",
    description:
      "Selected plans mention on-server snapshots or recovery options. For important workloads, keep your own backups because external backup is not implied.",
    icon: "bx:archive",
  },
  {
    title: "Docs, status, and support path",
    description:
      "Start from the docs at 8labs.id/docs for usage guidance, check public status when available, and use the client panel or Telegram community for account and provisioning help.",
    icon: "bx:support",
  },
];
---

<div class="mt-24">
  <div class="grid gap-6 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
    <div>
      <p class="font-semibold text-red-700 uppercase tracking-[0.2em] text-sm">Capabilities</p>
      <h2 class="mt-3 text-4xl font-bold tracking-[-0.04em] text-zinc-950 lg:text-6xl">
        Practical <span class="text-red-700">ngoprek</span>, less production risk.
      </h2>
    </div>
    <p class="max-w-2xl text-lg leading-8 text-zinc-600 lg:justify-self-end">
      Build, test, break, and rebuild in lab environments designed for developers, students, IT professionals, and homelab users—without treating production infrastructure as your playground.
    </p>
  </div>
</div>

<div class="mt-12 grid grid-cols-1 gap-px overflow-hidden rounded-3xl bg-zinc-200 border border-zinc-200 sm:grid-cols-2 md:grid-cols-3">
  {
    features.map((item, index) => (
      <div class="group min-h-[260px] bg-white p-6 transition-colors duration-300 hover:bg-zinc-950">
        <div class="flex items-center justify-between">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-zinc-950 text-white transition-colors duration-300 group-hover:bg-red-700">
            <Icon class="h-6 w-6" name={item.icon} />
          </div>
          <span class="font-mono text-xs text-zinc-300 transition-colors group-hover:text-zinc-600">
            0{index + 1}
          </span>
        </div>
        <h3 class="mt-14 text-xl font-bold tracking-[-0.03em] text-zinc-950 transition-colors group-hover:text-white">{item.title}</h3>
        <p class="mt-3 text-sm leading-7 text-zinc-600 transition-colors group-hover:text-zinc-300">{item.description}</p>
      </div>
    ))
  }
</div>
