---
const stats = [
  {
    number: "300+",
    text: "Machines Deployed",
  },
  {
    number: "99%",
    text: "Service Uptime",
  },
  {
    number: "24/7",
    text: "Support Available",
  },
];
---

<div class="mt-10">
  <div class="mx-auto max-w-5xl">
    <div
      class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 py-8 px-4 text-center bg-gradient-to-br from-slate-100 to-slate-200 rounded-lg">
      {
        stats.map((stat) => (
          <div class="flex flex-col items-center">
            <div class="text-4xl font-bold text-black lg:text-5xl">
              {stat.number}
            </div>
            <div class="text-slate-600 mt-2">{stat.text}</div>
          </div>
        ))
      }
    </div>
  </div>
</div>
