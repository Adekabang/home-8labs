---
// Docs header matching the 8labs.id navbar: same brand mark, same menu
// items, same pill language. Search + theme select stay from Starlight;
// ThemeSelect comes from starlight-blog so the Blog link is preserved.
import Search from "@astrojs/starlight/components/Search.astro";
import SocialIcons from "@astrojs/starlight/components/SocialIcons.astro";
import ThemeSelect from "starlight-blog/overrides/ThemeSelect.astro";

const products = [
  {
    title: "Virtual Labs",
    path: "https://my.8labs.id/products/virtual-labs",
  },
  {
    title: "Virtual Dedicated Labs",
    path: "https://my.8labs.id/products/virtual-dedicated-labs",
  },
  { title: "CloudLabs", path: "https://my.8labs.id/products/cloudlabs" },
  { title: "ElasticLabs", path: "https://my.8labs.id/products/elasticlabs" },
  {
    title: "ElasticLabs NAT",
    path: "https://my.8labs.id/products/elasticlabs-nat",
  },
];

const menuitems = [
  { title: "Services", path: "/services" },
  { title: "Pricing", path: "/pricing" },
  { title: "Docs", path: "/docs", active: true },
  { title: "Blog", path: "/blog" },
  { title: "Contact", path: "/contact" },
  { title: "Status", path: "https://uptime.8labs.id", external: true },
  { title: "Community", path: "https://t.me/virtual_8labs", external: true },
];
---

<div class="header">
  <div class="title-wrapper sl-flex">
    <a href="/" class="brand" aria-label="8Labs home">
      <span class="brand-name">8Labs</span><span class="brand-dot">.</span>
    </a>
    <a href="/docs" class="brand-docs">Docs</a>
    <nav class="main-nav" aria-label="Main site">
      <details class="nav-dropdown">
        <summary>
          Products
          <svg
            width="10"
            height="10"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            aria-hidden="true"><path d="m6 9 6 6 6-6"></path></svg
          >
        </summary>
        <ul class="nav-dropdown-panel">
          {
            products.map((p) => (
              <li>
                <a href={p.path} target="_blank" rel="noopener noreferrer">
                  {p.title}
                </a>
              </li>
            ))
          }
        </ul>
      </details>
      {
        menuitems.map((item) => (
          <a
            href={item.path}
            class:list={["nav-link", item.active && "nav-link-active"]}
            target={item.external ? "_blank" : undefined}
            rel={item.external ? "noopener noreferrer" : undefined}
            aria-current={item.active ? "true" : undefined}
          >
            {item.title}
          </a>
        ))
      }
    </nav>
  </div>
  <div class="sl-flex print:hidden">
    <Search />
  </div>
  <div class="sl-hidden md:sl-flex print:hidden right-group">
    <div class="sl-flex social-icons">
      <SocialIcons />
    </div>
    <ThemeSelect />
    <a
      href="https://my.8labs.id"
      target="_blank"
      rel="noopener noreferrer"
      class="client-panel">Client Panel</a
    >
  </div>
</div>

<style>
  .header {
    display: flex;
    gap: var(--sl-nav-gap);
    justify-content: space-between;
    align-items: center;
    height: 100%;
  }

  .title-wrapper {
    align-items: center;
    gap: 0.625rem;
    padding: 0.25rem;
    margin: -0.25rem;
    min-width: 0;
  }

  .brand {
    display: inline-flex;
    align-items: baseline;
    text-decoration: none;
    font-size: 1.125rem;
    font-family: "Bricolage Grotesque Variable", "Inter Variable", sans-serif;
    flex-shrink: 0;
  }
  .brand-name {
    font-weight: 700;
    color: var(--sl-color-white);
  }
  .brand-dot {
    font-weight: 700;
    color: #e60022;
  }
  .brand-docs {
    flex-shrink: 0;
    font-size: 0.8125rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--sl-color-accent-high);
    background: var(--sl-color-accent-low);
    border-radius: 9999px;
    padding: 0.125rem 0.625rem;
  }

  .main-nav {
    display: none;
  }

  .right-group,
  .social-icons {
    gap: 1rem;
    align-items: center;
  }
  .social-icons::after {
    content: "";
    height: 2rem;
    border-inline-end: 1px solid var(--sl-color-gray-5);
  }

  /* Client Panel: same black pill as the home navbar */
  .client-panel {
    flex-shrink: 0;
    white-space: nowrap;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.4375rem 1rem;
    border-radius: 9999px;
    background: var(--sl-color-white);
    color: var(--sl-color-black);
    transition: opacity 150ms ease;
  }
  .client-panel:hover {
    opacity: 0.85;
  }

  @media (min-width: 72rem) {
    .main-nav {
      display: flex;
      align-items: center;
      gap: 0.125rem;
      margin-inline-start: 0.75rem;
    }
    .nav-link {
      display: flex;
      align-items: center;
      white-space: nowrap;
      padding: 0.375rem 0.75rem;
      border-radius: 9999px;
      font-size: 0.875rem;
      text-decoration: none;
      color: var(--sl-color-gray-2);
      transition:
        background-color 150ms ease,
        color 150ms ease;
    }
    .nav-link:hover {
      background: var(--sl-color-gray-6);
      color: var(--sl-color-white);
    }
    .nav-link-active {
      color: var(--sl-color-accent);
      font-weight: 600;
    }

    .nav-dropdown {
      position: relative;
    }
    .nav-dropdown summary {
      display: flex;
      align-items: center;
      gap: 0.3125rem;
      list-style: none;
      cursor: pointer;
      white-space: nowrap;
      padding: 0.375rem 0.75rem;
      border-radius: 9999px;
      font-size: 0.875rem;
      color: var(--sl-color-gray-2);
      transition:
        background-color 150ms ease,
        color 150ms ease;
    }
    .nav-dropdown summary::-webkit-details-marker {
      display: none;
    }
    .nav-dropdown summary:hover {
      background: var(--sl-color-gray-6);
      color: var(--sl-color-white);
    }
    .nav-dropdown[open] summary svg {
      transform: rotate(180deg);
    }
    .nav-dropdown-panel {
      position: absolute;
      top: calc(100% + 0.5rem);
      inset-inline-start: 0;
      z-index: var(--sl-z-index-navbar, 10);
      min-width: 14rem;
      margin: 0;
      padding: 0.375rem;
      list-style: none;
      background: var(--sl-color-black);
      border: 1px solid var(--sl-color-gray-5);
      border-radius: 1rem;
      box-shadow: 0 18px 60px -45px rgba(0, 0, 0, 0.7);
    }
    .nav-dropdown-panel a {
      display: block;
      padding: 0.4375rem 0.75rem;
      border-radius: 0.625rem;
      font-size: 0.875rem;
      text-decoration: none;
      color: var(--sl-color-gray-2);
    }
    .nav-dropdown-panel a:hover {
      background: var(--sl-color-gray-6);
      color: var(--sl-color-white);
    }
  }

  @media (min-width: 50rem) {
    :global(:root[data-has-sidebar]) {
      --__sidebar-pad: calc(2 * var(--sl-nav-pad-x));
    }
    :global(:root:not([data-has-toc])) {
      --__toc-width: 0rem;
    }
    .header {
      --__sidebar-width: max(
        0rem,
        var(--sl-content-inline-start, 0rem) - var(--sl-nav-pad-x)
      );
      --__main-column-fr: calc(
        (
            100% + var(--__sidebar-pad, 0rem) -
              var(--__toc-width, var(--sl-sidebar-width)) -
              (2 * var(--__toc-width, var(--sl-nav-pad-x))) -
              var(--sl-content-inline-start, 0rem) - var(--sl-content-width)
          ) / 2
      );
      display: grid;
      grid-template-columns:
        minmax(
          calc(
            var(--__sidebar-width) +
              max(0rem, var(--__main-column-fr) - var(--sl-nav-gap))
          ),
          auto
        )
        1fr
        auto;
      align-content: center;
    }
  }
</style>

<script>
  // Close the Products dropdown when clicking outside or pressing Escape.
  document.querySelectorAll(".nav-dropdown").forEach((dd) => {
    document.addEventListener("click", (e) => {
      if (dd.hasAttribute("open") && !dd.contains(e.target as Node)) {
        dd.removeAttribute("open");
      }
    });
    dd.addEventListener("keydown", (e) => {
      if ((e as KeyboardEvent).key === "Escape") {
        dd.removeAttribute("open");
        (dd.querySelector("summary") as HTMLElement)?.focus();
      }
    });
  });
</script>
