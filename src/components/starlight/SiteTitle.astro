---
// Custom site title matching the 8labs.id navbar brand ("8Labs" + red dot)
// plus quick links back to the main site.
---

<div class="brand-wrap">
  <a href="/" class="brand" aria-label="8Labs home">
    <span class="brand-name">8Labs</span><span class="brand-dot">.</span>
  </a>
  <a href="/docs" class="brand-docs">Docs</a>
  <nav class="brand-links" aria-label="Main site">
    <a href="/pricing">Pricing</a>
    <a href="https://my.8labs.id" target="_blank" rel="noopener noreferrer"
      >Client Panel</a
    >
  </nav>
</div>

<style>
  .brand-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }
  .brand {
    display: inline-flex;
    align-items: baseline;
    text-decoration: none;
    font-size: 1.125rem;
    font-family: "Bricolage Grotesque Variable", "Inter Variable", sans-serif;
  }
  .brand-name {
    font-weight: 700;
    color: var(--sl-color-white);
  }
  .brand-dot {
    font-weight: 700;
    color: #e60022;
  }
  .brand-docs {
    font-size: 0.8125rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--sl-color-accent-high);
    background: var(--sl-color-accent-low);
    border-radius: 9999px;
    padding: 0.125rem 0.625rem;
  }
  .brand-links {
    display: none;
  }
  @media (min-width: 64rem) {
    .brand-links {
      display: flex;
      gap: 0.25rem;
    }
    .brand-links a {
      color: var(--sl-color-gray-2);
      text-decoration: none;
      font-size: 0.875rem;
      padding: 0.375rem 0.75rem;
      border-radius: 9999px;
    }
    .brand-links a:hover {
      background: var(--sl-color-gray-6);
      color: var(--sl-color-white);
    }
  }
</style>
