---
import { Picture } from "astro:assets";
import genreJatengImage from "assets/genre-jateng.png";

const partners = [
  {
    name: "Genre Jawa Tengah",
    image: genreJatengImage,
    url: "https://genrejateng.or.id",
    note: "Verified public trust signal",
  },
];
---

<section class="mt-16">
  <div class="mx-auto max-w-5xl rounded-2xl border border-slate-200 bg-white p-6 md:p-8 shadow-sm">
    <div class="text-center">
      <p class="font-semibold text-red-700 uppercase tracking-wide text-sm">
        Trusted by
      </p>
      <h2 class="mt-2 text-2xl md:text-3xl font-bold text-slate-900">
        Verified organization using 8Labs.
      </h2>
      <p class="mx-auto mt-3 max-w-2xl text-sm md:text-base text-slate-600">
        We only show partners or users that can be verified publicly. For now,
        this section intentionally highlights Genre Jawa Tengah rather than
        implying a larger customer-logo wall.
      </p>
    </div>

    <div class="mt-8 flex justify-center">
      {
        partners.map((partner) => (
          <a
            href={partner.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex w-full max-w-md flex-col items-center rounded-xl border border-slate-200 bg-slate-50 px-6 py-7 text-center transition-all hover:-translate-y-1 hover:border-red-200 hover:bg-white hover:shadow-lg"
            title={partner.name}>
            <div class="flex min-h-32 w-full items-center justify-center rounded-lg bg-white p-5 shadow-inner ring-1 ring-slate-100">
              <Picture
                src={partner.image}
                alt={`${partner.name} logo`}
                class="max-h-24 md:max-h-28 w-auto object-contain"
                loading="eager"
                format="png"
              />
            </div>
            <h3 class="mt-5 text-lg font-semibold text-slate-900">
              {partner.name}
            </h3>
            <p class="mt-1 text-sm text-slate-500">{partner.note}</p>
          </a>
        ))
      }
    </div>
  </div>
</section>
