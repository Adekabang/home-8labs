---
import { Picture } from "astro:assets";
import genreJatengImage from "assets/genre-jateng.png";

const partners = [
  {
    name: "Genre Jawa Tengah",
    image: genreJatengImage,
    url: "https://genrejateng.or.id",
  },
];
---

<div class="mt-10">
  <h2 class="text-center text-slate-500">Trusted by</h2>
  <div
    class="flex gap-8 md:gap-20 items-center justify-center mt-5 flex-wrap bg-black p-5 md:px-10 md:py-6 mx-auto max-w-5xl rounded-lg text-center">
    {
      partners.map((partner) => (
        <a
          href={partner.url}
          target="_blank"
          rel="noopener noreferrer"
          class="transition-transform hover:scale-110"
          title={partner.name}>
          <Picture
            src={partner.image}
            alt={partner.name}
            class="h-24 md:h-28 w-auto object-contain"
            loading="eager"
            format="png"
          />
        </a>
      ))
    }
  </div>
</div>
