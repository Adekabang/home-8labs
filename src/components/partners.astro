---
import { Picture } from "astro:assets";
import genreJatengImage from "assets/genre-jateng.png";

const partners = [
  {
    name: "Genre Jawa Tengah",
    image: genreJatengImage,
    url: "https://genrejateng.or.id",
  },
];
---

<div class="mt-24">
  <div class="mx-auto grid max-w-5xl items-center gap-8 rounded-[2rem] border border-zinc-200 bg-white p-8 shadow-[0_30px_90px_-60px_rgba(0,0,0,0.25)] md:p-12 lg:grid-cols-[1.15fr_0.85fr]">
    <div>
      <h2 class="text-3xl font-bold tracking-[-0.04em] text-zinc-950 md:text-4xl">Verified community trust signal.</h2>
      <p class="mt-4 max-w-md text-base leading-7 text-zinc-600">
        Showing only verified public trust assets. No invented customers, no filler logo wall.
      </p>
    </div>
    {
      partners.map((partner) => (
        <a
          href={partner.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex min-h-[160px] items-center justify-center rounded-3xl border border-zinc-200 bg-zinc-50 p-8 transition-all hover:-translate-y-1 hover:border-zinc-300 hover:bg-white"
          title={partner.name}>
          <Picture
            src={partner.image}
            alt={partner.name}
            class="h-24 w-auto object-contain md:h-28"
            loading="eager"
            format="png"
          />
        </a>
      ))
    }
  </div>
</div>
