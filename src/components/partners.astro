---
import { Picture } from "astro:assets";
import genreJatengImage from "assets/genre-jateng.png";

const partners = [
  {
    name: "Genre Jawa Tengah",
    image: genreJatengImage,
    url: "https://genrejateng.or.id",
  },
];
---

<div class="mt-24">
  <div class="mx-auto max-w-5xl overflow-hidden rounded-[2rem] border border-zinc-200 bg-white shadow-[0_30px_90px_-60px_rgba(0,0,0,0.45)]">
    <div class="grid items-center gap-px bg-zinc-200 lg:grid-cols-[0.85fr_1.15fr]">
      <div class="bg-zinc-950 p-8 text-white md:p-10">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-red-300">Trusted by</p>
        <h2 class="mt-3 text-3xl font-bold tracking-[-0.04em] md:text-4xl">Verified community trust signal.</h2>
        <p class="mt-4 text-sm leading-7 text-zinc-300">
          Showing only verified public trust assets. No invented customers, no filler logo wall.
        </p>
      </div>
      <div class="bg-white p-6 md:p-10">
        {
          partners.map((partner) => (
            <a
              href={partner.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex min-h-[160px] items-center justify-center rounded-3xl border border-zinc-200 bg-zinc-950 p-8 transition-transform hover:-translate-y-1"
              title={partner.name}>
              <Picture
                src={partner.image}
                alt={partner.name}
                class="h-24 w-auto object-contain drop-shadow-[0_10px_28px_rgba(255,255,255,0.22)] md:h-28"
                loading="eager"
                format="png"
              />
            </a>
          ))
        }
      </div>
    </div>
  </div>
</div>
