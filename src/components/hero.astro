---
import Link from "@components/ui/link.astro";
import HomelabTopology from "@components/motifs/homelab-topology.astro";
---

<section
  aria-label="Introduction"
  class="relative isolate mt-6 border border-grid bg-ink">
  <!-- corner registration marks -->
  <span class="bp-cross absolute -left-2 -top-2 h-4 w-4"></span>
  <span class="bp-cross absolute -right-2 -top-2 h-4 w-4"></span>
  <span class="bp-cross absolute -bottom-2 -left-2 h-4 w-4"></span>
  <span class="bp-cross absolute -bottom-2 -right-2 h-4 w-4"></span>

  <div class="grid min-h-[600px] lg:grid-cols-2">
    <div class="flex flex-col justify-center gap-7 px-6 py-16 md:px-12 lg:py-24">
      <p class="micro-label flex items-center gap-2 text-red-ink">
        <span class="inline-block h-2 w-2 bg-red-700"></span>
        Provisioned lab infrastructure
      </p>

      <h1 class="max-w-xl text-4xl font-medium leading-[1.05] tracking-[-0.03em] text-line text-balance sm:text-5xl lg:text-6xl">
        Spin up safe labs for <span class="text-red-ink">controlled failure</span>.
      </h1>

      <p class="max-w-md text-base leading-relaxed text-cool text-pretty">
        Provisioned environments for testing, learning, and controlled failure, with clear boundaries before anything reaches production.
      </p>

      <div class="flex flex-col gap-3 sm:flex-row">
        <Link href="https://my.8labs.id" target="_blank" rel="noopener noreferrer" size="md">
          Open client panel
        </Link>
        <Link href="/docs" style="outline" size="md">
          Read the docs
        </Link>
      </div>

      <dl class="mt-2 flex flex-wrap gap-x-10 gap-y-4 border-t border-grid pt-6">
        <div>
          <dt class="micro-label">Families</dt>
          <dd class="mt-1 text-2xl font-medium text-line">5</dd>
        </div>
        <div>
          <dt class="micro-label">Network</dt>
          <dd class="mt-1 text-2xl font-medium text-line">v6 / v4 / NAT</dd>
        </div>
        <div>
          <dt class="micro-label">Setup</dt>
          <dd class="mt-1 text-2xl font-medium text-line">1&ndash;15 min</dd>
        </div>
      </dl>
    </div>

    <!-- visual cell -->
    <div class="relative flex items-center justify-center border-grid bg-surface px-6 py-12 lg:border-l">
      <div class="absolute inset-0 bp-dots opacity-40 [mask-image:radial-gradient(circle_at_60%_45%,black,transparent_72%)]"></div>
      <span class="absolute left-4 top-4 micro-label">FIG.01 / LAB TOPOLOGY</span>

      <HomelabTopology class="relative z-10 w-full max-w-md" />

      <!-- annotation callout with corner brackets -->
      <figure class="absolute right-5 top-12 hidden max-w-[12rem] border border-line/30 bg-ink/90 p-3 backdrop-blur-sm lg:block">
        <figcaption class="micro-label text-line">Isolated lab</figcaption>
        <p class="mt-1 text-xs leading-snug text-cool">An experiment node, segmented from the rest of the homelab network.</p>
      </figure>
    </div>
  </div>
</section>
