---
import { Icon } from "astro-icon/components";

const trustItems = [
  {
    title: "Status link, with fallback awareness",
    description:
      "The site links to a public status route for availability checks. If that route has a certificate or availability issue, use the client panel or community path instead.",
    href: "https://uptime.8labs.id",
    label: "Open status",
    icon: "bx:pulse",
    external: true,
  },
  {
    title: "Docs and support path",
    description:
      "Product usage should start from the docs at 8labs.id/docs. Account, provisioning, or incident-specific issues belong in the client panel support path.",
    href: "/docs",
    label: "Read docs",
    icon: "bx:book-open",
    external: false,
  },
  {
    title: "Backup expectations",
    description:
      "8Labs terms state that users should perform their own backups and that backup availability or integrity is not guaranteed. Treat snapshots as convenience, not external backup.",
    href: "/tos",
    label: "Review terms",
    icon: "bx:archive",
    external: false,
  },
  {
    title: "Conservative security claims",
    description:
      "Public product pages mention DDoS or Anti-DDoS on selected product families. Security, abuse, or account-impacting reports should go through support with context.",
    href: "https://my.8labs.id",
    label: "Contact support",
    icon: "bx:shield-quarter",
    external: true,
  },
];
---

<section class="mt-24">
  <div class="relative overflow-hidden rounded-[2rem] bg-zinc-950 p-8 text-white md:p-10">
    <div class="absolute inset-0 opacity-25 [background-image:linear-gradient(rgba(255,255,255,.12)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,.12)_1px,transparent_1px)] [background-size:48px_48px]"></div>
    <div class="absolute -right-24 -top-24 h-72 w-72 rounded-full bg-red-700/30 blur-3xl"></div>

    <div class="relative grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
      <div>
        <h2 class="text-4xl font-bold tracking-[-0.04em] lg:text-6xl">
          Clear signals before users deploy workloads.
        </h2>
      </div>
      <p class="max-w-2xl text-lg leading-8 text-zinc-300 lg:justify-self-end">
        Labs are built for experimentation, but users still need to know where status, docs, backup expectations, and support paths live. This copy is intentionally conservative and avoids SLA or backup guarantees that are not stated in the public terms.
      </p>
    </div>

    <div class="relative mt-10 grid grid-cols-1 gap-4 md:grid-cols-2">
      {
        trustItems.map((item) => (
          <a
            href={item.href}
            target={item.external ? "_blank" : undefined}
            rel={item.external ? "noopener noreferrer" : undefined}
            class="group rounded-3xl border border-white/10 bg-white/[0.045] p-6 transition-all hover:-translate-y-1 hover:bg-white/[0.075]">
            <div class="flex items-start gap-4">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-white text-black transition-colors group-hover:bg-red-700 group-hover:text-white">
                <Icon class="h-6 w-6" name={item.icon} />
              </div>
              <div>
                <h3 class="text-lg font-bold tracking-[-0.02em]">{item.title}</h3>
                <p class="mt-2 text-sm leading-7 text-zinc-300">
                  {item.description}
                </p>
                <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-red-300">
                  {item.label} <Icon class="h-4 w-4 transition-transform group-hover:translate-x-1" name="bx:right-arrow-alt" />
                </span>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
