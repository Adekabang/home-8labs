---
import { Icon } from "astro-icon/components";

const trustItems = [
  {
    title: "Status link, with fallback awareness",
    description:
      "The site links to a public status route for availability checks. If that route has a certificate or availability issue, use the client panel or community path instead.",
    href: "https://uptime.8labs.id",
    label: "Open status",
    icon: "bx:pulse",
  },
  {
    title: "Docs and support path",
    description:
      "Product usage should start from docs.8labs.id. Account, provisioning, or incident-specific issues belong in the client panel support path.",
    href: "https://docs.8labs.id",
    label: "Read docs",
    icon: "bx:book-open",
  },
  {
    title: "Backup expectations",
    description:
      "8Labs terms state that users should perform their own backups and that backup availability or integrity is not guaranteed. Treat snapshots as convenience, not external backup.",
    href: "https://8labs.id/tos",
    label: "Review terms",
    icon: "bx:archive",
  },
  {
    title: "Conservative security claims",
    description:
      "Public product pages mention DDoS or Anti-DDoS on selected product families. Security, abuse, or account-impacting reports should go through support with context.",
    href: "https://my.8labs.id",
    label: "Contact support",
    icon: "bx:shield-quarter",
  },
];
---

<section class="mt-20">
  <div class="rounded-2xl bg-black text-white p-8 md:p-10">
    <div class="max-w-3xl">
      <p class="font-semibold text-red-300 uppercase tracking-wide text-sm">
        Trust, operations, and risk notes
      </p>
      <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight mt-2">
        Clear signals before users deploy workloads.
      </h2>
      <p class="text-slate-300 text-lg mt-4">
        Labs are built for experimentation, but users still need to know where
        status, docs, backup expectations, and support paths live. This copy is
        intentionally conservative and avoids SLA or backup guarantees that are
        not stated in the public terms.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mt-10">
      {
        trustItems.map((item) => (
          <a
            href={item.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group rounded-xl border border-white/10 bg-white/5 p-5 hover:bg-white/10 transition-colors">
            <div class="flex items-start gap-4">
              <div class="bg-white text-black rounded-lg p-3 group-hover:bg-red-700 group-hover:text-white transition-colors">
                <Icon class="w-6 h-6" name={item.icon} />
              </div>
              <div>
                <h3 class="font-semibold text-lg">{item.title}</h3>
                <p class="text-slate-300 text-sm leading-relaxed mt-2">
                  {item.description}
                </p>
                <span class="inline-flex items-center gap-1 text-sm font-semibold text-red-300 mt-4">
                  {item.label} <Icon class="w-4 h-4" name="bx:right-arrow-alt" />
                </span>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
