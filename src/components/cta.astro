---
import Link from "./ui/link.astro";
---

<div
  class="bg-black p-8 md:px-20 md:py-20 mt-20 mx-auto max-w-5xl rounded-lg flex flex-col items-center text-center">
  <h2 class="text-white text-4xl md:text-6xl tracking-tight">
    Ready to build your next lab?
  </h2>
  <p class="text-slate-400 mt-4 text-lg md:text-xl">
    Continue to the client panel to browse live products, stock, pricing, and
    billing units. If you are still exploring, start with docs and confirm backup
    expectations before putting important data on any lab.
  </p>
  <div class="flex flex-col sm:flex-row mt-5 gap-3">
    <Link href="https://my.8labs.id" style="inverted" target="_blank" rel="noopener noreferrer">
      Open Client Panel
    </Link>
    <Link href="https://docs.8labs.id" style="outline" target="_blank" rel="noopener noreferrer">
      Read Documentation
    </Link>
  </div>
</div>
