---
import Link from "./ui/link.astro";
import EndlessGrid from "@components/motifs/endless-grid.astro";
---

<div
  class="relative mt-32 mx-auto max-w-5xl overflow-hidden rounded-none border border-grid bg-ink px-6 py-24 md:px-20 md:py-32 text-center">
  <!-- Endless perspective grid: clear masked centre keeps text/buttons legible -->
  <EndlessGrid class="pointer-events-none absolute inset-0 h-full w-full" />
  <span class="bp-cross absolute left-1 top-1 h-4 w-4"></span>
  <span class="bp-cross absolute right-1 top-1 h-4 w-4"></span>
  <span class="bp-cross absolute bottom-1 left-1 h-4 w-4"></span>
  <span class="bp-cross absolute bottom-1 right-1 h-4 w-4"></span>
  <div class="relative">
    <p class="micro-label">Ready state</p>
    <h2 class="mt-4 text-line text-4xl font-light tracking-[-0.04em] md:text-6xl">
      Build your next <span class="font-normal text-red-ink">lab</span>.
    </h2>
    <div class="mt-10 flex flex-col sm:flex-row gap-3 justify-center">
      <Link href="https://my.8labs.id" target="_blank" rel="noopener noreferrer" size="md" class="rounded-none">
        Open client panel
      </Link>
      <Link href="/docs" style="outline" size="md" class="rounded-none">
        View architecture
      </Link>
    </div>
  </div>
</div>
