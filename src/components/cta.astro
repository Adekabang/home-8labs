---
import Link from "./ui/link.astro";
---

<div
  class="bg-black p-8 md:px-20 md:py-20 mt-20 mx-auto max-w-5xl rounded-lg flex flex-col items-center text-center">
  <h2 class="text-white text-4xl md:text-6xl tracking-tight">
    Explore & Build Faster.
  </h2>
  <p class="text-slate-400 mt-4 text-lg md:text-xl">
    Unlock the full potential of your home lab with 8Labs' robust and
    user-friendly cloud labs solutions. Start your journey today and see how
    easy and efficient building and managing your projects can be.
  </p>
  <div class="flex mt-5">
    <Link href="https://my.8labs.id/" style="inverted">Get Started Now</Link>
  </div>
</div>
