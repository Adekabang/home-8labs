---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import Link from "@components/ui/link.astro";
import { Icon } from "astro-icon/components";

const services = [
  {
    title: "Custom development & deployment",
    tag: "Project",
    icon: "bx:code-block",
    description:
      "Bespoke web apps and small SaaS, built and shipped end to end. Past work includes hosted multi-tenant platforms running in production.",
    includes: [
      "Scoped build from your requirements",
      "Deploy on 8Labs infra or your own server",
      "Handover, or keep it running with a retainer",
    ],
    audience: "For founders and teams that need a working product, not a slide deck.",
  },
  {
    title: "Open-source solution setup",
    tag: "Project",
    icon: "bx:cube",
    description:
      "Pick, deploy, and configure self-hosted open-source tools so you own the stack instead of renting another SaaS seat. A few common cases:",
    examples: [
      "Nextcloud — cloud storage & collaboration",
      "AI agents — automation & assistants",
      "Team chat & internal wiki",
      "Git hosting & CI",
    ],
    includes: [
      "Install, harden, and configure",
      "Reverse proxy, TLS, backups wired in",
      "Short runbook so you can operate it",
    ],
    audience: "For teams that want to own their stack instead of renting another SaaS seat.",
  },
  {
    title: "Security & monitoring",
    tag: "Project",
    icon: "bx:shield-quarter",
    description:
      "Visibility into your servers: log collection, alerting, and host hardening. Set up and tuned, with a review rhythm, not a 24/7 SOC claim.",
    includes: [
      "Log pipeline and alerting stood up",
      "Rules tuned to your real traffic",
      "Periodic review and alert triage",
    ],
    audience: "For teams that need eyes on their servers without a security hire.",
  },
  {
    title: "Managed & maintenance",
    tag: "Retainer",
    icon: "bx:wrench",
    description:
      "Keep what we deployed healthy: patching, monitoring, backup checks, and a direct line when something breaks.",
    includes: [
      "OS and app patching",
      "Uptime monitoring and backup verification",
      "Priority support over Telegram",
    ],
    audience: "For anyone who would rather not be the on-call engineer.",
  },
];

const steps = [
  {
    title: "Discovery call",
    body: "Free, 30 minutes. We figure out what you actually need and whether we are the right fit to build it.",
  },
  {
    title: "Scope & quote",
    body: "We write down the scope in plain language and give you a fixed quote. No surprise line items, no number before we both understand the work.",
  },
  {
    title: "Build & deploy",
    body: "We build it and ship it to your server or 8Labs infra. You see progress, not a black box.",
  },
  {
    title: "Handover or manage",
    body: "Take the keys and a runbook, or keep us on a retainer to run it for you.",
  },
];

const channels = [
  {
    label: "Book on Telegram",
    href: "https://t.me/virtual_8labs",
    icon: "bi:telegram",
    external: true,
  },
  {
    label: "Email hey@raska.id",
    href: "mailto:hey@raska.id",
    icon: "bi:envelope",
    external: false,
  },
];
---

<Layout title="Services">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Services</Fragment>
      <Fragment slot="desc">
        We deploy and run open-source solutions end to end, from a custom app to
        server security and monitoring. Indonesia-based and registered, you work
        directly with the engineer building it, not a sales layer.
      </Fragment>
    </Sectionhead>

    <div class="mx-auto mt-12 grid max-w-6xl grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-6">
      {
        services.map((service) => (
          <article
            class:list={[
              "group relative flex flex-col overflow-hidden rounded-none border border-grid bg-panel p-7 shadow-[0_1px_0_rgba(0,0,0,0.05)] transition-all duration-300 hover:border-red-700 hover:shadow-[0_30px_80px_-45px_rgba(194, 14, 80,0.45)] lg:col-span-3",
            ]}>
            <div class="flex items-center justify-between gap-4">
              <div class="flex h-12 w-12 items-center justify-center rounded-none border border-grid bg-surface text-line transition-colors duration-300 group-hover:bg-red-700 group-hover:text-white">
                <Icon class="h-6 w-6" name={service.icon} />
              </div>
              <span class="rounded-none border border-grid bg-elevated px-3 py-1 text-xs font-semibold uppercase tracking-wide text-muted">
                {service.tag}
              </span>
            </div>

            <h2 class="mt-6 text-2xl font-medium tracking-[-0.03em] text-line">
              {service.title}
            </h2>
            <p class="mt-3 text-sm leading-7 text-cool">{service.description}</p>

            {service.examples && (
              <div class="mt-4 flex flex-wrap gap-2">
                {service.examples.map((ex) => (
                  <span class="rounded-none border border-grid bg-elevated px-3 py-1 text-xs font-medium text-cool">
                    {ex}
                  </span>
                ))}
              </div>
            )}

            <ul class="mt-5 space-y-2">
              {service.includes.map((line) => (
                <li class="flex items-start gap-2 text-sm text-cool">
                  <Icon class="mt-0.5 h-4 w-4 shrink-0 text-red-ink" name="bx:check" />
                  <span>{line}</span>
                </li>
              ))}
            </ul>

            <p class="mt-5 text-sm font-medium leading-6 text-muted">
              {service.audience}
            </p>

            <a
              href="#start"
              class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-red-ink">
              Book a discovery call
              <Icon class="h-4 w-4 transition-transform group-hover:translate-x-1" name="bx:right-arrow-alt" />
            </a>
          </article>
        ))
      }
    </div>

    <section class="mx-auto mt-24 max-w-6xl">
      <h2 class="max-w-2xl text-3xl font-light tracking-[-0.04em] text-line md:text-4xl">
        How an engagement runs.
      </h2>
      <p class="mt-4 max-w-xl text-base leading-7 text-muted">
        No quote without a conversation first. Posting a fixed number before we
        understand the scope is how both sides get burned, so every job starts
        the same way.
      </p>

      <ol class="mt-10 grid grid-cols-1 gap-x-8 gap-y-10 sm:grid-cols-2 lg:grid-cols-4">
        {
          steps.map((step, i) => (
            <li class="border-t border-grid pt-5">
              <span class="font-mono text-sm font-semibold text-red-ink">
                {String(i + 1).padStart(2, "0")}
              </span>
              <h3 class="mt-3 text-lg font-medium tracking-[-0.02em] text-line">
                {step.title}
              </h3>
              <p class="mt-2 text-sm leading-7 text-cool">{step.body}</p>
            </li>
          ))
        }
      </ol>
    </section>

    <section
      id="start"
      class="mx-auto mt-24 max-w-6xl overflow-hidden rounded-none border border-grid bg-surface p-8 text-line md:p-12">
      <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
        <div>
          <h2 class="text-3xl font-medium tracking-[-0.03em] md:text-5xl">
            Start with a conversation, not a contract.
          </h2>
          <p class="mt-4 max-w-xl text-base leading-7 text-cool">
            Tell us what you are trying to build or keep running. The discovery
            call is free and there is no obligation to hire after it.
          </p>
        </div>
        <div class="flex flex-col gap-3 lg:items-end">
          {
            channels.map((c) => (
              <a
                href={c.href}
                target={c.external ? "_blank" : undefined}
                rel={c.external ? "noopener noreferrer" : undefined}
                class="inline-flex w-full items-center justify-center gap-2 rounded-none border border-grid bg-ink px-6 py-3 text-sm font-medium transition-colors hover:bg-elevated lg:w-auto">
                <Icon class="h-5 w-5" name={c.icon} />
                {c.label}
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </Container>
</Layout>
