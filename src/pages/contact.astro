---
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import Layout from "@layouts/Layout.astro";
import { Icon } from "astro-icon/components";

const channels = [
  {
    title: "Telegram",
    handle: "@virtual_8labs",
    description: "Fastest reply. Best for quick questions and provisioning help.",
    href: "https://t.me/virtual_8labs",
    cta: "Open Telegram",
    icon: "bi:telegram",
    external: true,
  },
  {
    title: "Email",
    handle: "hey@raska.id",
    description: "Better for billing, account, or anything that needs a record.",
    href: "mailto:hey@raska.id",
    cta: "Send an email",
    icon: "bi:envelope",
    external: false,
  },
];
---

<Layout title="Contact">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Contact</Fragment>
      <Fragment slot="desc">We are here to help.</Fragment>
    </Sectionhead>

    <div class="mx-auto mt-16 grid max-w-4xl gap-10 md:grid-cols-2">
      <div>
        <h2 class="text-2xl font-bold tracking-[-0.02em] text-gray-800">
          Reach the 8Labs team.
        </h2>
        <p class="mt-3 text-lg leading-relaxed text-slate-600">
          Questions about a lab, billing, or your account? Message us on
          Telegram for the fastest reply, or email us if you need a paper
          trail. For provisioning and order issues, the
          <a
            href="https://my.8labs.id"
            target="_blank"
            rel="noopener noreferrer"
            class="font-medium text-red-700 underline-offset-2 hover:underline"
            >client panel</a
          > support path is usually quickest.
        </p>
        <div class="mt-6 flex items-center gap-2 text-gray-600">
          <Icon class="h-4 w-4 text-gray-400" name="bi:pin-map" />
          <span>Indonesia</span>
        </div>
      </div>

      <div class="flex flex-col gap-4">
        {
          channels.map((c) => (
            <a
              href={c.href}
              target={c.external ? "_blank" : undefined}
              rel={c.external ? "noopener noreferrer" : undefined}
              class="group rounded-2xl border border-zinc-200 bg-white p-6 transition-all hover:-translate-y-1 hover:border-zinc-300 hover:shadow-[0_24px_70px_-50px_rgba(0,0,0,0.6)]"
            >
              <div class="flex items-start gap-4">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-zinc-950 text-white transition-colors group-hover:bg-red-700">
                  <Icon class="h-6 w-6" name={c.icon} />
                </div>
                <div>
                  <h3 class="text-lg font-bold tracking-[-0.02em] text-zinc-950">
                    {c.title}
                  </h3>
                  <p class="text-sm font-medium text-red-700">{c.handle}</p>
                  <p class="mt-2 text-sm leading-7 text-zinc-600">
                    {c.description}
                  </p>
                  <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-red-700">
                    {c.cta}
                    <Icon
                      class="h-4 w-4 transition-transform group-hover:translate-x-1"
                      name="bx:right-arrow-alt"
                    />
                  </span>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </Container>
</Layout>
