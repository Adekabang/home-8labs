---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import PricingCard from "@components/pricing.astro";

const pricing = [
  {
    name: "Virtual Labs",
    price: "LAB Coin",
    popular: true,
    features: [
      "Experiment-focused nested virtualization labs",
      "Small, Medium, and Large options shown in the client panel",
      "IPv6-first options, with selected plans including IPv4",
      "Usage is shown in LAB Coin billing units",
      "Check current stock and final billing unit before ordering",
    ],
    button: {
      text: "View Virtual Labs",
      link: "https://my.8labs.id/products/virtual-labs",
      target: "_blank",
    },
  },
  {
    name: "Virtual Dedicated Labs",
    price: "IDR plans",
    popular: false,
    features: [
      "Straight-up KVM virtual machines, no nesting involved",
      "Public IPv6 address",
      "On-server snapshots on listed plans",
      "External backup is not implied",
      "Suitable for predictable VM workloads",
    ],
    button: {
      text: "View VDL",
      link: "https://my.8labs.id/products/virtual-dedicated-labs",
      target: "_blank",
    },
  },
  {
    name: "Cloud & Elastic Labs",
    price: "IDR plans",
    popular: false,
    features: [
      "CloudLabs for higher bandwidth public IPv4/IPv6 options",
      "ElasticLabs for growable disk/resource tiers",
      "ElasticLabs NAT for lower-cost private IPv4 NAT labs",
      "Anti-DDoS or DDoS protection where listed per product",
      "Review product detail for location, transfer, and snapshots",
    ],
    button: {
      text: "Browse Catalog",
      link: "https://my.8labs.id",
      target: "_blank",
    },
  },
];
---

<Layout title="Pricing">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Product and pricing guide</Fragment>
      <Fragment slot="desc">
        8Labs pricing is finalized in the client panel. This page explains which
        product families use LAB Coin-style usage and which ones normally show
        IDR plans, so users know where to continue.
      </Fragment>
    </Sectionhead>

    <div class="grid md:grid-cols-3 gap-10 mx-auto max-w-screen-lg mt-12">
      {pricing.map((item) => <PricingCard plan={item} />)}
    </div>

    <div class="mx-auto max-w-screen-lg mt-10 rounded-none bg-panel border border-grid p-6 text-cool">
      <h2 class="font-medium text-line text-xl">Before ordering</h2>
      <p class="mt-2">
        Product availability, stock, billing unit, and final price can change in
        the client panel. Use this page as a routing guide, then confirm the
        exact plan details on my.8labs.id.
      </p>
      <p class="mt-2 text-sm">
        Important data should be backed up by the user unless a product
        explicitly states otherwise. Snapshots and external backups are not the
        same thing.
      </p>
    </div>
  </Container>
</Layout>
