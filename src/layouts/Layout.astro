---
import { SEO } from "astro-seo";
import { sitePages } from "../og-pages";
import Footer from "@components/footer.astro";
import Navbar from "@components/navbar/navbar.astro";
import "@fontsource-variable/inter/index.css";
import "@fontsource-variable/bricolage-grotesque";
import "../styles/global.css";

export interface Props {
  title: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const normalize = (p: string) => p.replace(/\/+$/, "") || "/";
const currentPath = normalize(Astro.url.pathname);
const ogSlug = Object.entries(sitePages).find(
  ([, p]) => normalize(p.path) === currentPath,
)?.[0];

// Home uses a real screenshot of the landing page; other pages use generated cards.
const ogImagePath =
  currentPath === "/" ? "/og-home.png" : ogSlug ? `/og/${ogSlug}.png` : "/opengraph.jpg";
const resolvedImageWithDomain = new URL(ogImagePath, Astro.site).toString();

const { title } = Astro.props;

const makeTitle = title ? title + " | " + "8Labs" : "8Labs - Virtual & Cloud Labs";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- <link rel="preload" as="image" href={src} alt="Hero" /> -->
    <SEO
      title={makeTitle}
      description="8Labs provides virtual and cloud lab environments for developers, students, IT professionals, and homelab enthusiasts, with product flows through my.8labs.id."
      canonical={canonicalURL}
      twitter={{
        creator: "@mraskaa_",
        site: "@mraskaa_",
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: makeTitle,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: "8Labs Homepage Screenshot",
        },
      }}
    />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Navbar />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <style is:global>
      /* Improve Page speed */
      /* https://css-tricks.com/almanac/properties/c/content-visibility/ */
      img {
        content-visibility: auto;
      }
    </style>
    <!-- Motif animations: run only while scrolled into view -->
    <script is:inline>
      (function () {
        var motifs = document.querySelectorAll("svg[data-motif]");
        if (!motifs.length) return;
        if (!("IntersectionObserver" in window)) return; // fallback: always animate
        motifs.forEach(function (m) {
          m.setAttribute("data-paused", "");
        });
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) e.target.removeAttribute("data-paused");
              else e.target.setAttribute("data-paused", "");
            });
          },
          { threshold: 0.2 },
        );
        motifs.forEach(function (m) {
          io.observe(m);
        });
      })();
    </script>
    <!-- Analytics -->
    <script
      defer
      src="https://beacon.8labs.id/script.js"
      data-website-id="2f166e07-ce01-415b-9b24-5e2d9290e058"></script>
  </body>
</html>
